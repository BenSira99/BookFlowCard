{
  "expo": {
    "name": "BookFlow Card",
    "slug": "BookFlowCard",
    "version": "1.0.0",
    "scheme": "bookflowcard",
    "orientation": "portrait",
    "icon": "./assets/BookFlowCard.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/BookFlowCard.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bensira99.bookflowcard",
      "icon": "./assets/BookFlowCard.png"
    },
    "android": {
      "package": "com.bensira99.bookflowcard",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/BookFlowCard.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/BookFlowCard.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
